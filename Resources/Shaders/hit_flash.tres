code = "shader_type canvas_item;
render_mode blend_mix;

uniform bool enabled = false;
uniform vec4 ColorParameter : source_color;



void fragment() {
// BooleanParameter:3
	bool n_out3p0 = enabled;


// ColorParameter:2
	vec4 n_out2p0 = ColorParameter;
	float n_out2p1 = n_out2p0.r;
	float n_out2p2 = n_out2p0.g;
	float n_out2p3 = n_out2p0.b;
	float n_out2p4 = n_out2p0.a;


// VectorCompose:7
	vec3 n_out7p0 = vec3(n_out2p1, n_out2p2, n_out2p3);


// VectorOp:6
	vec3 n_out6p0 = n_out7p0 * vec3(n_out2p4);


// FloatOp:10
	float n_in10p0 = 1.00000;
	float n_out10p0 = n_in10p0 - n_out2p4;


// Input:5
	vec4 n_out5p0 = COLOR;
	float n_out5p1 = n_out5p0.r;
	float n_out5p2 = n_out5p0.g;
	float n_out5p3 = n_out5p0.b;


// VectorCompose:8
	vec3 n_out8p0 = vec3(n_out5p1, n_out5p2, n_out5p3);


// VectorOp:9
	vec3 n_out9p0 = vec3(n_out10p0) * n_out8p0;


// VectorOp:11
	vec3 n_out11p0 = n_out6p0 + n_out9p0;


	vec3 n_out4p0;
// If:4
	float n_in4p1 = 1.00000;
	float n_in4p2 = 0.00001;
	if(abs((n_out3p0 ? 1.0 : 0.0) - n_in4p1) < n_in4p2)
	{
		n_out4p0 = n_out11p0;
	}
	else if((n_out3p0 ? 1.0 : 0.0) < n_in4p1)
	{
		n_out4p0 = vec3(n_out5p0.xyz);
	}
	else
	{
		n_out4p0 = vec3(n_out5p0.xyz);
	}


// Output:0
	COLOR.rgb = n_out4p0;


}
"
